Options +FollowSymLinks
RewriteEngine On

# Ensure www and https
# (Commented out for local XAMPP usage)
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^(.*)$ https://www.univindia.online/$1 [L,R=301]

# Hide .php extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Silo Routing
RewriteRule ^mgsu/results/?$ mgsu/results.php [NC,L]
RewriteRule ^mgsu/admit-card/?$ mgsu/admit-card.php [NC,L]
RewriteRule ^mgsu/syllabus/?$ mgsu/syllabus.php [NC,L]
RewriteRule ^mgsu/time-table/?$ mgsu/time-table.php [NC,L]
RewriteRule ^mgsu/exam-form/?$ mgsu/exam-form.php [NC,L]
RewriteRule ^mgsu/old-papers/?$ mgsu/old-papers.php [NC,L]

# Legal Static Routing
RewriteRule ^about-us/?$ about-us.php [NC,L]
RewriteRule ^contact-us/?$ contact-us.php [NC,L]
RewriteRule ^privacy-policy/?$ privacy-policy.php [NC,L]
RewriteRule ^disclaimer/?$ disclaimer.php [NC,L]
RewriteRule ^faq/?$ faq.php [NC,L]

# Custom Error Pages
ErrorDocument 404 /index.php
